---
import "../styles/global.css";
import { Font } from "astro:assets";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Ruby Mykkanen</title>
    <Font cssVariable="--font-oswald" preload />
    <Font cssVariable="--font-lato" preload />
    <Font cssVariable="--font-cutive-mono" preload />
    <!-- Add inside <head> -->
    <script src="https://tweakcn.com/live-preview.min.js"></script>
  </head>
  <body>
    <Header />
    <main class="layout-base my-8 gap-8 min-h-svh items-start content-start">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    /*height: 100%;*/
    background-image: url("../assets/background.webp");
    background-size: cover;
    background-position: top;
    background-repeat: no-repeat;
    font-family: var(--font-cutive-mono);
    font-size: 18px;
  }
</style>
