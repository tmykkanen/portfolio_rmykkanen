---
import Layout from "@/layouts/Layout.astro";
import Text from "@/components/Text.astro";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
  CardFooter,
  CardMedia,
} from "@/components/ui/card";
import { Image } from "astro:assets";
import projectImage from "@/assets/projects/electronics.webp";
---

<Layout>
  <Text as="h1" variant="mainHeading">Projects</Text>
  <div class="grid md:grid-cols-2 gap-8">
    <Card class:list={"w-full gap-4 py-4"}>
      <CardHeader class="px-4">
        <CardTitle>
          <Text as="a" variant="majorHeading" href={"/projects/project-1"}>
            Learning how to Build Simple Electronic Circuits using Breadboads
            and Arduino
          </Text>
        </CardTitle>
      </CardHeader>
      <CardContent class="flex gap-4 flex-col md:flex-row px-4">
        <CardMedia class="sm:flex-1"
          ><Image src={projectImage} alt="Electronics project" /></CardMedia
        >
        <Text class={"flex-2"}>
          In this project, I acqured some basic electronic parts for the purpose
          of teaching myslef how to make more complex circuits, and integrate
          computer programming.
        </Text>
      </CardContent>
    </Card>
    <Card class:list={"w-full gap-4 py-4"}>
      <CardHeader class="px-4">
        <CardTitle>
          <Text variant="majorHeading">
            Learning how to Build Simple Electronic Circuits using Breadboads
            and Arduino
          </Text>
        </CardTitle>
      </CardHeader>
      <CardContent class="flex gap-4 flex-col md:flex-row px-4">
        <CardMedia class="sm:flex-1"
          ><Image src={projectImage} alt="Electronics project" /></CardMedia
        >
        <Text class={"flex-2"}>
          In this project, I acqured some basic electronic parts for the purpose
          of teaching myslef how to make more complex circuits, and integrate
          computer programming.
        </Text>
      </CardContent>
    </Card>
  </div>
</Layout>
